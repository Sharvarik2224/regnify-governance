MONGODB_URI=
MONGODB_DB_NAME=regnify_hr
MONGODB_EMPLOYEES_COLLECTION=employees
MONGODB_SIGNATURES_COLLECTION=signatures
MONGODB_DIGITAL_CERTIFICATES_COLLECTION=digital_certificates
MONGODB_DOCUMENT_AUDIT_COLLECTION=document_audit
MONGODB_HR_DATA_COLLECTION=hr_data
PUBLIC_BASE_URL=http://localhost:5000
PORT=5000

# n8n credential automation
N8N_SENDPASS_WEBHOOK_URL=https://regnify-2.app.n8n.cloud/webhook/sendpass
# Optional: shared secret sent in x-regnify-signature header to n8n webhook
N8N_SENDPASS_WEBHOOK_SECRET=abcde
# Required: n8n uses this bearer token when calling backend callback to set generated passcode
N8N_SERVICE_TOKEN=12345
